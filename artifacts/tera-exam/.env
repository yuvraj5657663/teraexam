# ============================================================
# TERA EXAM — Frontend (Vite) Environment
# Variables prefixed with VITE_ are exposed to the browser.
# ============================================================

# Dev server port
PORT=5173

# API server URL — empty string means same-origin (proxy or monolith).
# For standalone frontend pointing at separate backend:
# VITE_API_URL=http://localhost:3001
VITE_API_URL=

# Base path (leave as / unless deploying to a sub-path)
BASE_PATH=/
