# ============================================================
# TERA EXAM — API Server Environment Configuration
# ============================================================
# NEVER commit real secrets to version control.
# Copy this to .env.local and fill in production values.
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL via Neon or any Postgres provider)
DATABASE_URL=postgresql://neondb_owner:npg_uvYaQSD8CH2c@ep-billowing-truth-at2a6fxs.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT — CHANGE THIS to a random 64-char string in production!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=my-super-secret-key-change-in-production-minimum-32-chars

# Session secret — CHANGE THIS in production!
SESSION_SECRET=my-session-secret-change-in-production-minimum-32-chars

# CORS — comma-separated allowed origins. Leave empty or use * to allow all (dev only).
# Production example: ALLOWED_ORIGINS=https://teraexam.in,https://www.teraexam.in
ALLOWED_ORIGINS=*

# Cloudinary (optional — only needed for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin seed (used only by the seed script, not at runtime)
ADMIN_SEED_PASSWORD=admin123

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
